# KavziTrader Configuration
KT_LOG_LEVEL=DEBUG

# Database Configuration
KT_DB_HOST=127.0.0.1
KT_DB_PORT=5432
KT_DB_USER=postgres
KT_DB_PASSWORD=postgres
KT_DB_NAME=kavzitrader

# API Credentials
KT_BINANCE_API_KEY=your_binance_api_key
KT_BINANCE_API_SECRET=your_binance_api_secret

# OpenRouter LLM Configuration
KT_OPENROUTER_API_KEY=your_openrouter_api_key

# External Sources
# CCData news does not require an API key

# System Settings
KT_DATA_DIR=data/
KT_MODELS_DIR=models/
KT_RESULTS_DIR=results/
KT_TIMEZONE=UTC

# Database Connection Settings
KT_DB_POOL_SIZE=10
KT_DB_MAX_OVERFLOW=20
KT_DB_ECHO=false
KT_DB_ECHO_POOL=false
KT_DB_CONNECT_TIMEOUT=10
KT_DB_CLIENT_ENCODING=utf8
KT_DB_APPLICATION_NAME=kavzitrader
