<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="refresh" content="{{ refresh_interval_s }}">
    <title>KavziTrader - Session Report</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet"
          integrity="sha384-QWTKZyjpPEjISv5WaRU9OFeRpok6YctnYmDr5pNlyT2bRjXh0JMhjY6hW+ALEwIH"
          crossorigin="anonymous">
    <style>
        .revenue-positive { color: #22c55e; font-weight: bold; }
        .revenue-negative { color: #ef4444; font-weight: bold; }
        .revenue-zero { opacity: 0.6; }
        .badge-scout { background-color: #6b7280; }
        .badge-analyst { background-color: #6d9e97; }
        .badge-trader { background-color: #c2795a; }
        .badge-execution { background-color: #9678a5; }
        .badge-position { background-color: #7a9bb5; }
        .stat-value {
            font-size: 1.5rem;
            font-weight: 700;
            font-variant-numeric: tabular-nums;
        }
        .stat-label {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
        }
    </style>
</head>
<body>
    <div class="container-fluid mt-3 mb-3">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h4 class="mb-0">KavziTrader Session Report</h4>
            <span class="text-body-secondary">
                Started: {{ state.session_started_at }}
                &middot; Updated: {{ state.last_updated_at }}
                &middot; v{{ state.version }}
            </span>
        </div>

        <div class="d-flex gap-4 align-items-end mb-4 pb-3 border-bottom">
            <div>
                <div class="stat-label text-body-secondary">Current Balance</div>
                <div class="stat-value">${{ "%.2f" | format(state.current_balance_usdt | float) }}</div>
            </div>
            <div class="vr"></div>
            <div>
                <div class="stat-label text-body-secondary">Session Revenue</div>
                {% set rev = state.session_revenue_usdt | float %}
                <div class="stat-value {% if rev > 0 %}revenue-positive{% elif rev < 0 %}revenue-negative{% else %}revenue-zero{% endif %}">
                    {% if rev >= 0 %}+{% endif %}${{ "%.2f" | format(rev) }}
                </div>
            </div>
            <div class="vr"></div>
            <div>
                <div class="stat-label text-body-secondary">Unrealized PnL</div>
                {% set pnl = state.unrealized_pnl_usdt | float %}
                <div class="stat-value {% if pnl > 0 %}revenue-positive{% elif pnl < 0 %}revenue-negative{% else %}revenue-zero{% endif %}">
                    {% if pnl >= 0 %}+{% endif %}${{ "%.2f" | format(pnl) }}
                </div>
            </div>
            <div class="vr"></div>
            <div>
                <div class="stat-label text-body-secondary">Active Positions</div>
                <div class="stat-value">{{ state.active_positions_count }}</div>
            </div>
        </div>

        {% if state.market_prices %}
        <div class="d-flex flex-wrap gap-4 align-items-end mb-3 pb-3 border-bottom">
            {% for mp in state.market_prices %}
            <div>
                <div class="stat-label text-body-secondary">{{ mp.symbol }}</div>
                <div class="fw-bold" style="font-variant-numeric: tabular-nums;">${{ "%.2f" | format(mp.price | float) }}</div>
            </div>
            {% if not loop.last %}<div class="vr"></div>{% endif %}
            {% endfor %}
        </div>
        {% endif %}

        {% if state.open_positions %}
        <div class="card mb-3">
            <div class="card-header fw-semibold">
                Open Positions
                <span class="badge text-bg-secondary ms-1">{{ state.open_positions | length }}</span>
            </div>
            <div class="card-body p-0">
                <table class="table table-sm table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Symbol</th>
                            <th>Side</th>
                            <th>Qty</th>
                            <th>Entry</th>
                            <th>Current</th>
                            <th>SL</th>
                            <th>TP</th>
                            <th>If SL</th>
                            <th>If TP</th>
                            <th>PnL</th>
                            <th>Lev</th>
                            <th>Opened</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for pos in state.open_positions %}
                        <tr>
                            <td><strong>{{ pos.symbol }}</strong></td>
                            <td>
                                {% if pos.side == "LONG" %}
                                <span class="badge bg-success">LONG</span>
                                {% else %}
                                <span class="badge bg-danger">SHORT</span>
                                {% endif %}
                            </td>
                            <td>{{ pos.quantity }}</td>
                            <td>{{ pos.entry_price }}</td>
                            <td>{{ pos.current_price }}</td>
                            <td>{{ pos.stop_loss }}</td>
                            <td>{{ pos.take_profit }}</td>
                            <td>
                                {% if pos.side == "LONG" %}
                                    {% set max_loss = ((pos.entry_price | float) - (pos.stop_loss | float)) * (pos.quantity | float) * -1 %}
                                {% else %}
                                    {% set max_loss = ((pos.stop_loss | float) - (pos.entry_price | float)) * (pos.quantity | float) * -1 %}
                                {% endif %}
                                <span class="revenue-negative">${{ "%.2f" | format(max_loss) }}</span>
                            </td>
                            <td>
                                {% if pos.side == "LONG" %}
                                    {% set target_profit = ((pos.take_profit | float) - (pos.entry_price | float)) * (pos.quantity | float) %}
                                {% else %}
                                    {% set target_profit = ((pos.entry_price | float) - (pos.take_profit | float)) * (pos.quantity | float) %}
                                {% endif %}
                                <span class="revenue-positive">+${{ "%.2f" | format(target_profit) }}</span>
                            </td>
                            <td>
                                {% set pnl_val = pos.unrealized_pnl | float %}
                                <span class="{% if pnl_val > 0 %}revenue-positive{% elif pnl_val < 0 %}revenue-negative{% else %}revenue-zero{% endif %}">
                                    {% if pnl_val >= 0 %}+{% endif %}${{ "%.2f" | format(pnl_val) }}
                                </span>
                            </td>
                            <td>{{ pos.leverage }}x</td>
                            <td><small>{{ pos.opened_at.strftime('%H:%M:%S') if pos.opened_at is not string else pos.opened_at }}</small></td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
        {% endif %}

        <div class="row g-3">
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-header fw-semibold">
                        Trade Actions
                        <span class="badge text-bg-secondary ms-1">{{ state.trades | length }}</span>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-striped mb-0">
                            <thead>
                                <tr>
                                    <th>Time</th>
                                    <th>Symbol</th>
                                    <th>Side</th>
                                    <th>Price</th>
                                    <th>Qty</th>
                                    <th>SL</th>
                                    <th>TP</th>
                                    <th>Status</th>
                                    <th>Conf</th>
                                </tr>
                            </thead>
                            <tbody>
                                {% for trade in state.trades | reverse %}
                                <tr>
                                    <td><small>{{ trade.timestamp.strftime('%H:%M:%S') if trade.timestamp is not string else trade.timestamp }}</small></td>
                                    <td><strong>{{ trade.symbol }}</strong></td>
                                    <td>
                                        {% if trade.side == "LONG" %}
                                        <span class="badge bg-success">LONG</span>
                                        {% elif trade.side == "SHORT" %}
                                        <span class="badge bg-danger">SHORT</span>
                                        {% else %}
                                        <span class="badge bg-warning text-dark">CLOSE</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ trade.entry_price if trade.entry_price is not none else '-' }}</td>
                                    <td>{{ trade.quantity if trade.quantity is not none else '-' }}</td>
                                    <td>{{ trade.stop_loss if trade.stop_loss is not none else '-' }}</td>
                                    <td>{{ trade.take_profit if trade.take_profit is not none else '-' }}</td>
                                    <td>
                                        {% if trade.status == "FILLED" %}
                                        <span class="badge bg-success">{{ trade.status }}</span>
                                        {% elif trade.status == "REJECTED" %}
                                        <span class="badge bg-danger">{{ trade.status }}</span>
                                        {% elif trade.status == "EXPIRED" %}
                                        <span class="badge bg-secondary">{{ trade.status }}</span>
                                        {% else %}
                                        <span class="badge bg-info">{{ trade.status }}</span>
                                        {% endif %}
                                    </td>
                                    <td>{{ "%.0f" | format(trade.confidence * 100) }}%</td>
                                </tr>
                                {% if trade.reasoning %}
                                <tr>
                                    <td colspan="9"><small class="text-body-secondary">{{ trade.reasoning }}</small></td>
                                </tr>
                                {% endif %}
                                {% endfor %}
                                {% if not state.trades %}
                                <tr>
                                    <td colspan="9" class="text-center text-body-secondary py-3">No trades yet</td>
                                </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="col-lg-5">
                <div class="card">
                    <div class="card-header fw-semibold">
                        Activity Log
                        <span class="badge text-bg-secondary ms-1">{{ state.actions | length }}</span>
                    </div>
                    <div class="card-body p-0">
                        <table class="table table-sm table-striped mb-0">
                            <tbody>
                                {% for action in state.actions | reverse %}
                                <tr>
                                    <td class="text-nowrap" style="width: 1%">
                                        <small class="text-body-secondary">{{ action.timestamp.strftime('%H:%M:%S') if action.timestamp is not string else action.timestamp }}</small>
                                    </td>
                                    <td class="text-nowrap" style="width: 1%">
                                        {% if "scout" in action.action_type %}
                                        <span class="badge badge-scout">{{ action.action_type }}</span>
                                        {% elif "analyst" in action.action_type %}
                                        <span class="badge badge-analyst">{{ action.action_type }}</span>
                                        {% elif "trader" in action.action_type %}
                                        <span class="badge badge-trader">{{ action.action_type }}</span>
                                        {% elif action.action_type in ("order_created", "order_rejected", "order_filled") %}
                                        <span class="badge badge-execution">{{ action.action_type }}</span>
                                        {% else %}
                                        <span class="badge badge-position">{{ action.action_type }}</span>
                                        {% endif %}
                                    </td>
                                    <td class="text-nowrap" style="width: 1%"><strong>{{ action.symbol }}</strong></td>
                                    <td>
                                        {{ action.summary }}
                                        {% if action.details %}
                                        <br><small class="text-body-secondary">{{ action.details }}</small>
                                        {% endif %}
                                    </td>
                                </tr>
                                {% endfor %}
                                {% if not state.actions %}
                                <tr>
                                    <td colspan="4" class="text-center text-body-secondary py-3">No activity yet</td>
                                </tr>
                                {% endif %}
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <noscript>
        <p class="text-warning text-center mt-2">
            JavaScript is disabled. Auto-refresh relies on the meta refresh tag.
        </p>
    </noscript>
</body>
</html>
