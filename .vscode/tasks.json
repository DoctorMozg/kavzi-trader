{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Docker Compose Services",
      "type": "shell",
      "command": "docker compose -p kavzitrader up -d",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "icon": {
        "id": "server"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "options": {
        "cwd": "${workspaceFolder}/docker",
        "statusbar": {
            "color": "#a8e6d1"
        }
      },
      "problemMatcher": [],
      "detail": "Start PostgreSQL, Redis, and PgAdmin containers defined in docker-compose.yml"
    },
    {
      "label": "Pre-Commit Hooks",
      "type": "shell",
      "command": "uv run pre-commit run --all-files",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "icon": {
        "id": "check-all"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "options": {
        "statusbar": {
            "color": "#bd95e2"
        }
      },
      "problemMatcher": [],
      "detail": "Run pre-commit hooks"
    },
    {
      "label": "Run KavziTrader",
      "type": "shell",
      "command": "uv run python -m kavzi_trader.cli.main trade start",
      "icon": {
        "id": "rocket"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "options": {
        "statusbar": {
            "color": "#f5a623"
        }
      },
      "problemMatcher": [],
      "detail": "Start the trading orchestrator with config/config.yaml"
    },
    {
      "label": "Run KavziTrader (Paper)",
      "type": "shell",
      "command": "uv run python -m kavzi_trader.cli.main trade start --paper",
      "icon": {
        "id": "beaker"
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "options": {
        "statusbar": {
            "color": "#4ecdc4"
        }
      },
      "problemMatcher": [],
      "detail": "Start the trading orchestrator in paper mode with simulated orders"
    }
  ]
}
