# Docker environment variables for KavziTrader

# PostgreSQL configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=kavzitrader
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Redis configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# PgAdmin configuration
PGADMIN_DEFAULT_EMAIL=admin@kavzitrader.com
PGADMIN_DEFAULT_PASSWORD=admin

# Airflow configuration (uncomment when needed)
# AIRFLOW_UID=50000
# AIRFLOW__CORE__EXECUTOR=LocalExecutor
# AIRFLOW__CORE__LOAD_EXAMPLES=False

# TimescaleDB configuration (uncomment when needed)
# TIMESCALEDB_USER=postgres
# TIMESCALEDB_PASSWORD=postgres
# TIMESCALEDB_DB=kavzitrader_timeseries
# TIMESCALEDB_HOST=timescaledb
# TIMESCALEDB_PORT=5432

# Application configuration
APP_ENV=development
APP_DEBUG=true

# Binance API credentials (replace with your own values)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
